{
  "name": "@zod-monaco/core",
  "version": "2.1.1",
  "description": "Zod v4 runtime bridge for JSON Schema generation and validation",
  "license": "MIT",
  "author": "Kaan Akin",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "zod",
    "json-schema",
    "validation"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsc --watch -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:hover-audit": "vitest run src/__tests__/hover-audit.test.ts",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "typescript": "5.9.2",
    "vitest": "^4.1.1",
    "zod": "^4.0.0"
  }
}
